# Production build default (Vite reads this during `npm run build` / Cloudflare Pages).
# Makes the deployed dashboard FETCH /api/snapshot and overlay live data instead of
# rendering the pure MOCK_DATA baseline. Mock remains the always-present runtime fallback
# (graceful degradation) — any fetch/parse failure silently reverts to mock, so the
# dashboard never breaks. An explicit VITE_DATA_MODE var in the Pages dashboard overrides this.
VITE_DATA_MODE=live
